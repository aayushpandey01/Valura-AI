        "expected_agent": "portfolio_health",
        "expected_entities": {}
      },
      {
        "role": "user",
        "content": "Am I too concentrated?",
        "expected_agent": "portfolio_health",
        "expected_entities": {}
      },
      {
        "role": "user",
